# Banco de dados (SQLite). Caminho relativo à raiz do projeto (onde os
# comandos são rodados), não à pasta prisma/. Em produção na VPS, pode-se
# usar um caminho absoluto em vez de "file:./prisma/situr.db".
DATABASE_URL="file:./prisma/situr.db"

# Painel administrativo
ADMIN_PASSWORD=situr2026

# InfinitePay — sua InfiniteTag (o "$nome" da conta, pode incluir ou não o $).
# O Checkout Integrado é gratuito e não precisa de chave de API:
# https://www.infinitepay.io/checkout
INFINITEPAY_HANDLE=

# (Produção) URL pública do site, usada no retorno do checkout.
# Ex.: https://siturturismo.com.br
NEXT_PUBLIC_SITE_URL=

# (Produção, opcional) Webhook para confirmação imediata dos pagamentos.
# Ex.: https://siturturismo.com.br/api/checkout/webhook
INFINITEPAY_WEBHOOK_URL=

# Login com Google (opcional — sem ele o botão simplesmente não aparece).
# Crie em https://console.cloud.google.com/apis/credentials
# (OAuth client ID → Web application; adicione as origens do site).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Confirmação automática por e-mail (opcional — sem isso, nenhum e-mail é
# enviado). Funciona com Gmail, Outlook, ou qualquer provedor SMTP.
# Exemplo com Gmail: crie uma "senha de app" em myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Confirmação automática por WhatsApp via WhatsApp Cloud API — opcional e
# avançado (exige app Meta Business + número comercial verificado).
# Sem isso configurado, o envio automático fica desativado, mas o admin
# sempre tem um botão para enviar a confirmação manualmente com 1 clique.
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
